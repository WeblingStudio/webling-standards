# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Runtime environment — controls logging, error detail, and optimizations
# Values: development | test | production
NODE_ENV=development

# Port the server listens on (optional — defaults to 3000)
PORT=3000


# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# Full connection string for the primary database (required)
DATABASE_URL=


# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────

# Secret used to sign session tokens — generate with: openssl rand -base64 32 (required)
AUTH_SECRET=

# OAuth provider client credentials (required if using OAuth)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=


# ─────────────────────────────────────────────
# Third-party Services
# ─────────────────────────────────────────────

# Add service-specific keys here, grouped by provider
# PROVIDER_API_KEY=
